# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=kafka-ts-demo
KAFKA_GROUP_ID=kafka-ts-demo-group

# Topic Configuration
DEMO_TOPIC=demo-topic
USER_EVENTS_TOPIC=user-events
ORDER_EVENTS_TOPIC=order-events
TRANSACTION_TOPIC=transaction-topic

# Consumer Configuration
CONSUMER_SESSION_TIMEOUT=30000
CONSUMER_HEARTBEAT_INTERVAL=3000
CONSUMER_AUTO_COMMIT_INTERVAL=5000

# Producer Configuration
PRODUCER_BATCH_SIZE=16384
PRODUCER_LINGER_MS=10
PRODUCER_COMPRESSION_TYPE=gzip

# Monitoring
METRICS_INTERVAL=10000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/kafka-demo.log

# Environment
NODE_ENV=development